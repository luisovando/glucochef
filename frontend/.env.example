# Frontend .env.local — copy to .env.local and fill in real values. Never commit .env.local.
# Deploy independently from backend; this file documents every variable this service needs.
# Next.js loads .env.local automatically in development.

# ── Backend API (Phase 14+) ──────────────────────────────────────────────────
# URL of the deployed backend service. Use localhost for local dev.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AWS Cognito — client-side auth (Phase 15+) ───────────────────────────────
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
