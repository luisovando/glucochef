# Frontend .env.local — copy to .env.local and fill in real values. Never commit .env.local.
# This service deploys independently from the backend.
# Every variable this service needs is documented here.
#
# Next.js loads .env.local automatically in development (gitignored by the
# standard Next.js .gitignore). Variables prefixed NEXT_PUBLIC_ are bundled
# into the client-side build and are visible in the browser — do NOT put
# secrets here. Server-side secrets belong in the backend service only.

# ── Backend API (Phase 14 — Frontend bootstrap) ───────────────────────────────
# URL of the deployed backend. Use localhost for local dev, the AWS URL for prod.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── AWS Cognito — sign-in UI (Phase 15) ──────────────────────────────────────
# Find these values in AWS Console → Cognito → User Pools.
# Must match the same pool configured in backend/.env (COGNITO_USER_POOL_ID, etc.).
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
