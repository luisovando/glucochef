# Backend .env — copy to .env and fill in real values. Never commit .env.
# This service deploys independently from the frontend.
# Every variable this service needs is documented here.

# ── Database (Phase 2+) ──────────────────────────────────────────────────────
# Must match POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB in the root .env
# (consumed by docker-compose). Update the credentials in both files together.
DATABASE_URL=postgresql+asyncpg://glucochef:change_me@localhost:5432/glucochef

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=GlucoChef Backend
# Set DEBUG=true only in local development — never in staging or production.
DEBUG=false
# Values: development | staging | production
ENVIRONMENT=development
# SQL_ECHO enables SQLAlchemy statement logging (including bind parameters).
# Bind parameters may contain PHI — never enable in staging or production.
SQL_ECHO=false

# ── AWS Cognito — JWT auth (Phase 4) ─────────────────────────────────────────
# Find these values in the AWS Console → Cognito → User Pools.
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── PHI field-level encryption key (Phase 5) ─────────────────────────────────
# Must be a valid 32-byte Fernet key (url-safe base64). "change_me" is NOT valid.
# Generate a key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotate via key versioning — never reuse a key across environments.
ENCRYPTION_KEY=REPLACE_WITH_GENERATED_FERNET_KEY

# ── AI provider (Phase 8) ────────────────────────────────────────────────────
# Set exactly one key. The provider is selected via ADR-004 abstraction layer.
# Leave the unused key empty — do not delete the line.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
