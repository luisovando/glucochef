# Backend .env — copy to .env and fill in real values. Never commit .env.
# Deploy independently from frontend; this file documents every variable this service needs.

# ── Database (Phase 2+) ──────────────────────────────────────────────────────
# Must match the POSTGRES_USER/PASSWORD/DB in the root .env (docker-compose).
DATABASE_URL=postgresql+asyncpg://glucochef:change_me@localhost:5432/glucochef

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=GlucoChef Backend
DEBUG=false
ENVIRONMENT=development

# ── AWS Cognito — JWT auth (Phase 4) ─────────────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_REGION=us-east-1
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── PHI encryption key (Phase 5) ─────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me

# ── AI provider (Phase 8) ────────────────────────────────────────────────────
# Set exactly one of the two keys below depending on the provider chosen in Phase 8.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
