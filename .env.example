# Root .env — read by Docker Compose only. Never commit .env.
# Copy this file to .env and replace the placeholder values.
#
# This file intentionally contains only the three PostgreSQL bootstrap variables.
# Backend and frontend runtime variables live in their own service-level files:
#   backend/.env.example  — all backend variables (database URL, Cognito, encryption, AI)
#   frontend/.env.example — all frontend variables (API URL, Cognito client config)
#
# The DATABASE_URL in backend/.env must use the same credentials set here.

POSTGRES_USER=glucochef
POSTGRES_PASSWORD=change_me
POSTGRES_DB=glucochef
