# Copy this file to .env and fill in real values. Never commit .env.

# PostgreSQL (used by docker-compose and the backend)
POSTGRES_USER=glucochef
POSTGRES_PASSWORD=change_me
POSTGRES_DB=glucochef

# Backend — must match the docker-compose postgres credentials above
DATABASE_URL=postgresql+asyncpg://glucochef:change_me@localhost:5432/glucochef

# Application
APP_NAME=GlucoChef Backend
DEBUG=false
ENVIRONMENT=development
